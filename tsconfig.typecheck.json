{
  "extends": "./tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts"
  ],
  "exclude": [
    "src/renderer/src/**/*.test.ts",
    "src/renderer/src/**/*.test.tsx",
    "src/renderer/src/**/*.spec.ts",
    "src/renderer/src/**/*.spec.tsx"
  ],
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "noEmit": true
  }
}
